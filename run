#!/usr/bin/env bash

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

PORT=8081

show_help() {
    cat <<'EOF'
Usage: bash run [command] [maven args]

Commands:
  --help, -h  Show this help message
  clean       Run clean and start the app
  clean-test  Run mvn clean test
  clean-owasp, co
               Run clean and OWASP Dependency-Check scan
  deps        Print Maven dependency tree for vulnerability tracing
  fix-deps    Show available dependency and plugin updates
  hard-clean  Remove target and local project Maven cache, then start the app
  test        Run unit/integration tests
  verify      Run mvn clean verify
  owasp       Run OWASP Dependency-Check scan
  <none>      Start the app

Examples:
  bash run
  bash run clean
  bash run clean-test
  bash run verify
  bash run owasp
  bash run clean-owasp
  bash run deps
  bash run fix-deps
  bash run test
  bash run --help
EOF
}

run_owasp_check() {
    read -s -p "Enter NVD API Key: " NVD_API_KEY
    echo
    export NVD_API_KEY
    ./mvnw clean verify org.owasp:dependency-check-maven:check \
    -Dnvd.api.key="$NVD_API_KEY" \
    -Ddependency-check.offline=true
    unset NVD_API_KEY
}

# ./mvnw spring-boot:run \
#   -Dspring-boot.run.arguments="--server.port=$PORT"

# Forward all arguments to mvnw
# ./mvnw "$@" spring-boot:run \
#   -Dspring-boot.run.arguments="--server.port=$PORT"

# Check if the first argument is a supported command
if [[ "$1" == "--help" || "$1" == "-h" ]]; then
    show_help
    exit 0
elif [[ "$1" == "clean" ]]; then
    MVN_CMD="./mvnw clean spring-boot:run"
    # Shift so any additional args go to mvnw
    shift
elif [[ "$1" == "check" ]]; then
    shift
    run_owasp_check "$@"
    exit $?
    # Shift so any additional args go to mvnw
elif [[ "$1" == "owasp" ]]; then
    shift
    run_owasp_check "$@"
    exit $?
elif [[ "$1" == "clean-owasp" || "$1" == "co" ]]; then
    shift
    run_owasp_check "$@"
    exit $?
elif [[ "$1" == "deps" ]]; then
    shift
    ./mvnw dependency:tree "$@"
    exit $?
elif [[ "$1" == "fix-deps" ]]; then
    shift
    ./mvnw versions:display-dependency-updates versions:display-plugin-updates "$@"
    exit $?
elif [[ "$1" == "test" ]]; then
    shift
    ./mvnw test "$@"
    exit $?
elif [[ "$1" == "clean-test" ]]; then
    shift
    ./mvnw clean test "$@"
    exit $?
elif [[ "$1" == "verify" ]]; then
    shift
    ./mvnw clean verify "$@"
    exit $?
elif [[ "$1" == "hard-clean" ]]; then
    # ← clears Maven target + Spring devtools cache
    echo "🧹 Hard cleaning..."
    rm -rf target/
    rm -rf ~/.m2/repository/com/hkimhab/  # ← your group id
    MVN_CMD="./mvnw clean spring-boot:run"
    shift
else
    MVN_CMD="./mvnw spring-boot:run"
fi

# Forward any remaining arguments and set server port
$MVN_CMD "$@" -Dspring-boot.run.arguments="--server.port=$PORT"
